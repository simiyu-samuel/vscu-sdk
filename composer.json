{
    "name": "simiyu-samuel/vscu-sdk",
    "description": "Standalone PHP SDK for KRA VSCU invoice payloads and requests.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SimiyuSamuel\\VscuSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimiyuSamuel\\VscuSdk\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "scripts": {
        "test": "./vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
